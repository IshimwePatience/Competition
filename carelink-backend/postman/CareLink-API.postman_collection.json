{
  "info": {
    "name": "CareLink API v1",
    "description": "Health & Community Wellbeing Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "adminEmail", "value": "admin@carelink.local" },
    { "key": "adminPassword", "value": "change-this-admin-password" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": { "method": "GET", "url": "{{baseUrl}}/../health" }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@test.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\",\n  \"latitude\": -1.29,\n  \"longitude\": 36.82\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var json = pm.response.json();", "if(json.data && json.data.token) pm.collectionVariables.set('token', json.data.token);"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Triage",
      "item": [
        {
          "name": "Analyze Symptoms",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symptoms\": \"I have had a mild headache and runny nose for 2 days, no fever\"\n}"
            },
            "url": "{{baseUrl}}/triage/analyze"
          }
        },
        {
          "name": "Triage History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/triage/history"
          }
        }
      ]
    },
    {
      "name": "Facilities",
      "item": [
        {
          "name": "List All",
          "request": { "method": "GET", "url": "{{baseUrl}}/facilities" }
        },
        {
          "name": "Nearby",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/facilities/nearby?latitude=-1.29&longitude=36.82&radiusKm=15&type=clinic",
              "host": ["{{baseUrl}}"],
              "path": ["facilities", "nearby"],
              "query": [
                { "key": "latitude", "value": "-1.29" },
                { "key": "longitude", "value": "36.82" },
                { "key": "radiusKm", "value": "15" },
                { "key": "type", "value": "clinic" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Submit Report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isOpen\": true,\n  \"waitTimeMinutes\": 30,\n  \"crowdLevel\": \"moderate\",\n  \"notes\": \"Busy but accepting patients\"\n}"
            },
            "url": "{{baseUrl}}/reports/FACILITY_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Credits",
      "item": [
        {
          "name": "Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/credits/balance"
          }
        },
        {
          "name": "Redeem Screening",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/credits/redeem"
          }
        }
      ]
    }
  ]
}
