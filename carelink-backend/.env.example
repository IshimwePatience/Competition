NODE_ENV=development
PORT=5000

# Local PostgreSQL (source for npm run db:migrate-supabase)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=carelink
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=your-local-postgres-password

# PostgreSQL — Supabase Session Pooler
# Get password: Supabase Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_SUPABASE_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DB_SSL=true

# Or individual vars:
# DB_HOST=aws-0-eu-central-1.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres.PROJECT_REF
# DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# JWT
JWT_SECRET=your-long-random-jwt-secret
JWT_EXPIRES_IN=7d

# Admin (created automatically on first startup — no registration needed)
ADMIN_EMAIL=admin@carelink.local
ADMIN_PASSWORD=change-this-admin-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=CareLink

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# SMTP (email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# CORS
CLIENT_URL=http://localhost:5173
